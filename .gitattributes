# Auto-detect text files and normalize to LF in repo
* text=auto eol=lf

# Windows-specific scripts MUST keep CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# Source code — force LF
*.py    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.json  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.spec  text eol=lf

# Binary files — never normalize
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.wav   binary
*.mp3   binary
*.zip   binary
*.exe   binary
*.dll   binary
*.pyd   binary
*.whl   binary
*.pdf   binary
